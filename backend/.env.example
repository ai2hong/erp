# PostgreSQL example
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vapeerp

# JWT secrets (generate with: openssl rand -hex 32)
SECRET_KEY=replace_with_random_secret_key_min_32_chars
REFRESH_SECRET_KEY=replace_with_another_random_secret_key_min_32_chars

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

APP_NAME=VAPE DOG ERP
DEBUG=true
